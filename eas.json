{
  "cli": {
    "version": ">= 16.20.1",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "store",
      "environment": "preview",

      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "@EXPO_PUBLIC_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "@EXPO_PUBLIC_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID": "@EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS": "@EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_EDGE": "@EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_EDGE",
        "EXPO_PUBLIC_PROJECT_ID": "@EXPO_PUBLIC_PROJECT_ID",
        "EXPO_PUBLIC_SENTRY_DSN": "@EXPO_PUBLIC_SENTRY_DSN",
        "APP_VARIANT": "preview"
      }
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "@EXPO_PUBLIC_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "@EXPO_PUBLIC_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID": "@EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS": "@EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_EDGE": "@EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_EDGE",
        "EXPO_PUBLIC_PROJECT_ID": "@EXPO_PUBLIC_PROJECT_ID",
        "EXPO_PUBLIC_SENTRY_DSN": "@EXPO_PUBLIC_SENTRY_DSN",
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleTeamId": "9KVXT96KRA"
      },
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6753623462",
        "appleTeamId": "9KVXT96KRA",
        "ascApiKeyPath": "keys/asc-key.p8",
        "ascApiKeyIssuerId": "feeaa7ff-076c-4eb7-8f9a-45745c7c395a",
        "ascApiKeyId": "HJULJRS532"
      },
      "android": {
        "track": "production"
      }
    },
    "alpha": {
      "android": {
        "track": "alpha"
      }
    }
  }
}
