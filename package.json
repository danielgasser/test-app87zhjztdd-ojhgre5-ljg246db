{
  "name": "truguide",
  "version": "1.3.3",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "dev": "expo start --clear --reset-cache",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest --watchAll=false",
    "eas-build-on-success": "if [ \"$EAS_BUILD_PROFILE\" = \"production\" ]; then npx bugsnag-eas-build-on-success; fi"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/?(*.)+(spec|test).[tj]s?(x)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/asyncStorage.ts",
      "^../services/supabase$": "<rootDir>/src/__mocks__/services/supabase.ts",
      "^@/services/supabase$": "<rootDir>/src/__mocks__/services/supabase.ts",
      "^@/utils/notificationService$": "<rootDir>/src/__mocks__/utils/notificationService.ts",
      "^@/utils/logger$": "<rootDir>/src/__mocks__/utils/logger.ts",
      "^../../services/supabase$": "<rootDir>/src/__mocks__/services/supabase.ts",
      "^../../../services/supabase$": "<rootDir>/src/__mocks__/services/supabase.ts",
      "^@react-native-community/netinfo$": "<rootDir>/src/__mocks__/netinfo.ts",
      "^../services/offlineQueue$": "<rootDir>/src/__mocks__/services/offlineQueue.ts",
      "^../../services/offlineQueue$": "<rootDir>/src/__mocks__/services/offlineQueue.ts"
    },
    "setupFiles": [
      "<rootDir>/src/jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/src/store/__tests__/helpers/"
    ]
  },
  "dependencies": {
    "@2toad/profanity": "^3.2.0",
    "@bugsnag/expo": "^54.0.0",
    "@bugsnag/expo-performance": "^54.0.0",
    "@gorhom/portal": "^1.0.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli": "^20.0.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.6",
    "@reduxjs/toolkit": "^2.8.2",
    "@supabase/supabase-js": "^2.52.0",
    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "~54.0.25",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.10.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "qs": "^6.14.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.1",
    "react-native-maps": "1.20.1",
    "react-native-purchases": "^9.6.11",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.1",
    "react-native-webview": "13.15.0",
    "react-redux": "^9.2.0",
    "supabase": "^2.84.10",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/eslintrc": "^3.3.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "baseline-browser-mapping": "^2.9.19",
    "eslint-config-expo": "^10.0.0",
    "eslint-plugin-i18next": "^6.1.3",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "svgo": "^3.3.3",
    "tar": ">=7.5.10",
    "@tootallnate/once": ">=3.0.1"
  },
  "private": true
}
